# ── Twilio (SMS / WhatsApp / RCS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_PHONE=+15005550006
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # optional

# ── AWS SES (email) ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SES_FROM_ADDRESS=hello@example.com
SES_FROM_NAME=Example
SES_CONFIGURATION_SET=nudge-events    # optional, for open/click tracking

# ── Vonage (SMS / WhatsApp fallback) ──────────────────────────────────────
VONAGE_API_KEY=xxxxxxxx
VONAGE_API_SECRET=xxxxxxxxxxxxxxxx
VONAGE_FROM_NUMBER=+15005550006
VONAGE_WHATSAPP_NUMBER=+15005550007  # optional

# ── MessageBird ────────────────────────────────────────────────────────────
MESSAGEBIRD_API_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MESSAGEBIRD_ORIGINATOR=NudgeApp
MESSAGEBIRD_WHATSAPP_CHANNEL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # optional

# ── Firebase FCM (Android push) ────────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project
FCM_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}  # JSON string

# ── APNs (iOS push) ────────────────────────────────────────────────────────
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.example.app
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_SANDBOX=true    # set to false for production

# ── iMessage Business Chat ─────────────────────────────────────────────────
NUDGE_IMESSAGE_BUSINESS_ID=your-business-id

# ── Redis (cross-process idempotency) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Compliance ────────────────────────────────────────────────────────────
NUDGE_10DLC_REGISTERED=true   # set after completing 10DLC registration

# ── OpenTelemetry ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nudge

# ── Webhook server ────────────────────────────────────────────────────────
NUDGE_WEBHOOK_PORT=3001
